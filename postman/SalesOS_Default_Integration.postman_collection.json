{
  "info": {
    "name": "SalesOS Default Integration",
    "description": "Send numbered activities (001-999) from any CRM to SalesOS.\n\nAuthentication: Bearer sk_live_YOUR_API_KEY\nScope: default:sync",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{API_KEY}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "https://api.play2sell.com",
      "type": "string"
    },
    {
      "key": "API_KEY",
      "value": "sk_live_YOUR_API_KEY",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Sync Collaborators — Single",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{BASE_URL}}/functions/v1/default-integration",
          "host": ["{{BASE_URL}}"],
          "path": ["functions", "v1", "default-integration"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"sync_collaborators\",\n  \"collaborators\": [\n    {\n      \"external_id\": \"emp-101\",\n      \"name\": \"Maria Santos\",\n      \"email\": \"maria@yourcompany.com\",\n      \"team\": \"Sales Team A\",\n      \"role\": \"sales_rep\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "2. Sync Collaborators — Full Team",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{BASE_URL}}/functions/v1/default-integration",
          "host": ["{{BASE_URL}}"],
          "path": ["functions", "v1", "default-integration"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"sync_collaborators\",\n  \"collaborators\": [\n    {\n      \"external_id\": \"emp-101\",\n      \"name\": \"Maria Santos\",\n      \"email\": \"maria@yourcompany.com\",\n      \"phone\": \"+5511999001001\",\n      \"document\": \"12345678901\",\n      \"team\": \"Equipe Vendas SP\",\n      \"role\": \"vendedor\",\n      \"metadata\": { \"crm_id\": \"CRM-2001\" }\n    },\n    {\n      \"external_id\": \"emp-102\",\n      \"name\": \"Joao Silva\",\n      \"email\": \"joao@yourcompany.com\",\n      \"team\": \"Equipe Vendas SP\",\n      \"role\": \"vendedor\"\n    },\n    {\n      \"external_id\": \"emp-103\",\n      \"name\": \"Ana Oliveira\",\n      \"email\": \"ana@yourcompany.com\",\n      \"team\": \"Equipe Vendas RJ\",\n      \"role\": \"gerente\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "3. Sync Activities — Single",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{BASE_URL}}/functions/v1/default-integration",
          "host": ["{{BASE_URL}}"],
          "path": ["functions", "v1", "default-integration"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"sync_activities\",\n  \"activities\": [\n    {\n      \"activity_code\": \"001\",\n      \"external_id\": \"crm-call-5001\",\n      \"collaborator_email\": \"maria@yourcompany.com\",\n      \"data\": { \"client\": \"Acme Corp\", \"duration_min\": 12 },\n      \"occurred_at\": \"2026-03-17T09:15:00-03:00\"\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "4. Sync Activities — Daily Batch",
      "request": {
