        ],
        "url": {
          "raw": "{{BASE_URL}}/functions/v1/default-integration",
          "host": ["{{BASE_URL}}"],
          "path": ["functions", "v1", "default-integration"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"sync_activities\",\n  \"activities\": [\n    {\n      \"activity_code\": \"abc\",\n      \"external_id\": \"test-1\",\n      \"collaborator_email\": \"maria@co.com\"\n    }\n  ]\n}"
